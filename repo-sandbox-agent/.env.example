# Required: Groq API key for LLM inference
GROQ_API_KEY=gsk_...

# Optional: Google AI API key (fallback when Groq quota is exhausted)
# GOOGLE_AI_API_KEY=AIza...

# ── Model override ──────────────────────────────────────────────────────────
# Each Groq model has its OWN daily token quota — switch models when one hits
# its limit. New API keys do NOT reset quotas (quota is per-project, not per-key).
#
# Groq free-tier daily TPD limits:
#   llama-3.3-70b-versatile                  100 000 TPD  ← default
#   llama-3.1-8b-instant                     500 000 TPD  ← fastest fallback
#   meta-llama/llama-4-scout-17b-16e-instruct 500 000 TPD  ← richest context
#
# Google free-tier daily limits:
#   gemini-2.0-flash        50 RPD  (hits quickly on long sessions)
#   gemini-2.0-flash-lite   1500 RPD (better for high-frequency use)
#
# Examples:
# MODEL=groq:llama-3.1-8b-instant node index.js
# MODEL=google:gemini-2.0-flash-lite node index.js
MODEL=groq:llama-3.3-70b-versatile
